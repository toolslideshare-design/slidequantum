# Public site URL (used for SEO metadata and sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API base URL (when you add a backend)
NEXT_PUBLIC_API_URL=/api

# Admin authentication (change these in production)
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_SECRET=change-this-to-a-long-random-secret-key

# User authentication sessions (change this in production)
USER_AUTH_SECRET=change-this-to-another-long-random-secret-key
