# Public site URL (used for SEO metadata and sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API base URL (when you add a backend)
NEXT_PUBLIC_API_URL=/api

# Admin authentication (change these in production)
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_SECRET=change-this-to-a-long-random-secret-key

# User authentication sessions (change this in production)
USER_AUTH_SECRET=change-this-to-another-long-random-secret-key

# Production admin storage (required on Vercel for saving admin settings)
# 1. Vercel Dashboard → Storage → Upstash Redis → Connect to project
# 2. Vercel auto-adds these variables — redeploy after connecting:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional legacy names (also supported by @vercel/kv if present):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
